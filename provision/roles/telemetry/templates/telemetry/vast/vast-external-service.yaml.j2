---
{% if telemetry_config.telemetry_sources.vast.metrics_enabled | default(false) | bool %}
apiVersion: v1
kind: Service
metadata:
  name: vast-external
  namespace: {{ telemetry_namespace }}
  labels:
    app: vast-external
    app.kubernetes.io/managed-by: omnia
    app.kubernetes.io/component: vast-telemetry
spec:
  ports:
    - name: metrics
      port: {{ telemetry_config.vast_configuration.vast_metrics_port | default(443) }}
  clusterIP: None

---
apiVersion: v1
kind: Endpoints
metadata:
  name: vast-external
  namespace: {{ telemetry_namespace }}
subsets:
  - addresses:
      - ip: "{{ telemetry_config.vast_configuration.vast_endpoint }}"
    ports:
      - name: metrics
        port: {{ telemetry_config.vast_configuration.vast_metrics_port | default(443) }}
{% endif %}
