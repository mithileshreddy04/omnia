---
# Vector-OME ConfigMap
# Purpose: Store Vector TOML configuration for OME pipeline
# Spec Reference: Vector HLD Engineering Spec (ESPEC-VECTOR-2026-001) §4.1.3.2, CD-10

apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ vector.ome.app_name }}-config
  namespace: {{ telemetry_namespace }}
  labels:
    app: {{ vector.ome.app_name }}
    component: telemetry-bridge
    subsystem: ome
    managed-by: omnia
data:
  vector.toml: |
{{ lookup('template', 'telemetry/vector/vector-ome-config.toml.j2') | indent(4, first=True) }}
