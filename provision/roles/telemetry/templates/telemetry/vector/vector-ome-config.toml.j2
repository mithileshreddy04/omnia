# Vector-OME Configuration
# Purpose: Consume OME telemetry from Kafka topics matching ome.* pattern,
#          route metrics to VictoriaMetrics via vmagent-vector and
#          route logs/events to VictoriaLogs via vlagent-vector
# Architecture: Kafka 'ome.*' topics → Vector-OME → vmagent-vector:8429 (metrics)
#                                                  → vlagent-vector:9427 (logs)
# Q2 Status: Active — Omnia-deployed
# Spec Reference: Vector HLD Engineering Spec (ESPEC-VECTOR-2026-001) §4.1.3.2, CD-10

# ============================================================================
# Data Directory
# ============================================================================
data_dir = "/var/lib/vector"

# ============================================================================
# SOURCE: Kafka Consumer for OME Topics (regex subscription)
# ============================================================================
# OME publishes to 5 topics: ome.events, ome.alerts, ome.inventory, ome.logs, ome.telemetry,
# Uses regex subscription to capture all OME topics dynamically (Constraint C-05)
[sources.kafka_ome]
type = "kafka"
bootstrap_servers = "kafka-kafka-bootstrap.{{ telemetry_namespace }}.svc.cluster.local:9093"
group_id = "{{ vector.ome.consumer_group }}"
topics = ['{{ vector.ome.kafka_topics_pattern }}']
auto_offset_reset = "earliest"
session_timeout_ms = 30000
fetch_wait_max_ms = 100

# Kafka mTLS authentication (dedicated vector-ome-user KafkaUser secret)
[sources.kafka_ome.tls]
enabled = true
ca_file = "/etc/vector/kafka-ca/ca.crt"
crt_file = "/etc/vector/kafka-certs/user.crt"
key_file = "/etc/vector/kafka-certs/user.key"
verify_certificate = true
verify_hostname = true

# Decoding: OME produces JSON messages
[sources.kafka_ome.decoding]
codec = "json"

# ============================================================================
# TRANSFORM: Extract Topic Name for Routing
# ============================================================================
# Step 1: Preserve the Kafka topic name for downstream routing decisions
[transforms.parse_ome_topic]
type = "remap"
inputs = ["kafka_ome"]
source = '''
  .source_topic = to_string(.topic) ?? "unknown"
'''

# ============================================================================
# TRANSFORM: OME Topic Router
# ============================================================================
# Step 2: Route by topic — metric topics to VictoriaMetrics, event/log topics to VictoriaLogs
# ome.inventory + ome.telemetry → metrics path (Redfish System[].Metric[] format)
# ome.events + ome.alerts + ome.logs → logs path (JSON events)
[transforms.ome_topic_router]
type = "route"
inputs = ["parse_ome_topic"]

  [transforms.ome_topic_router.route]
{% if telemetry_config.telemetry_bridges.vector_ome.metrics_enabled | default(false) | bool %}
  metrics = '.source_topic == "ome.inventory" || .source_topic == "ome.telemetry"'
{% endif %}
{% if telemetry_config.telemetry_bridges.vector_ome.logs_enabled | default(false) | bool %}
  logs = '.source_topic == "ome.events" || .source_topic == "ome.alerts" || .source_topic == "ome.logs"'
{% endif %}

{% if telemetry_config.telemetry_bridges.vector_ome.metrics_enabled | default(false) | bool %}
# ============================================================================
# TRANSFORM: Metric Enricher — Flatten OME Redfish System[].Metric[] Arrays
# ============================================================================
# Step 3: OME telemetry/inventory data uses Redfish nested array format.
# Each message has System[] with Metric[] sub-arrays. This transform flattens
# the nested structure into individual metric events for log_to_metric consumption.
[transforms.metric_enricher]
type = "remap"
inputs = ["ome_topic_router.metrics"]
source = '''
  all_metrics = []
  SystemArr = array!(.System)

  for_each(SystemArr) -> |_index, system| {
    for_each(array!(system.Metric)) -> |_index1, metric| {
      id_replaced = replace!(metric.MetricId, ".", "_")
      parts = split(id_replaced, "_")
      part_count = length(parts)
      sliced, _ = slice(parts, 1, (part_count - 2))
      metric_name, _ = join(sliced, "_")
      componentId = if exists(metric.ComponentId) && metric.ComponentId != null {
              metric.ComponentId
          } else {
              "System"
          }
      parsed_metric, _ = [{
        "MetricName": metric_name,
        "MetricValue": to_float(metric.MetricValue[0]),
        "ComponentId": componentId,
        "TimeStamp": metric.TimeStamp[0],
        "Identifier": system.Identifier,
        "Type": parts[0]
      }]

      all_metrics = append(all_metrics, parsed_metric)
    }
  }

  . = all_metrics
'''

# ============================================================================
# TRANSFORM: Log-to-Metric Conversion (MANDATORY for prometheus_remote_write)
# ============================================================================
# Step 4: Convert fan-out log events to Prometheus gauge metrics
# The prometheus_remote_write sink ONLY accepts metric-type events.
# Without this transform, all events are silently dropped by the sink.
[transforms.ome_to_metrics]
type = "log_to_metric"
inputs = ["metric_enricher"]

{% raw %}
  [[transforms.ome_to_metrics.metrics]]
  type = "gauge"
  field = "MetricValue"
  name = "{{ MetricName }}"

    [transforms.ome_to_metrics.metrics.tags]
    component = "{{ ComponentId }}"
    identifier = "{{ Identifier }}"
    type = "{{ Type }}"
{% endraw %}
    source_subsystem = "ome"
{% endif %}

{% if telemetry_config.telemetry_bridges.vector_ome.logs_enabled | default(false) | bool %}
# ============================================================================
# TRANSFORM: Log Enricher — Enrich Event/Alert/Log Messages for VictoriaLogs
# ============================================================================
# Step 5: Enrich non-metric events with VictoriaLogs-compatible fields
# _msg: full JSON-encoded message body
# _time: timestamp from OME event or current time
# _msg_source: "ome" for source identification
# _msg_topic: original Kafka topic name
# severity: extracted from OME Severity field
[transforms.ome_log_enricher]
type = "remap"
inputs = ["ome_topic_router.logs"]
source = '''
  ._msg = encode_json(.)
  raw_ts = to_string(.Timestamp) ?? ""
  parsed_ts, parse_err = parse_timestamp(raw_ts, "%Y%m%dT%H%M%SZ")
  if parse_err == null {
    ._time = format_timestamp!(parsed_ts, "%Y-%m-%dT%H:%M:%SZ")
  } else {
    ._time = to_string(now())
  }
  ._msg_source = "ome"
  ._msg_topic = to_string(.source_topic) ?? "ome"
  .severity = to_string(.Severity) ?? "info"
'''
{% endif %}

# ============================================================================
# SINK: Drop unmatched topics (suppresses _unmatched warning)
# ============================================================================
# Topics not matching metrics or logs routes (e.g. ome.health) are dropped
[sinks.drop_unmatched]
type = "blackhole"
inputs = ["ome_topic_router._unmatched"]

# ============================================================================
# SINKS
# ============================================================================

{% if telemetry_config.telemetry_bridges.vector_ome.metrics_enabled | default(false) | bool %}
# SINK: Prometheus Remote Write to vmagent-vector (Metrics)
# Data flow: Vector-OME → vmagent-vector:8429 → vminsert:8480
[sinks.victoria_metrics]
type = "prometheus_remote_write"
inputs = ["ome_to_metrics"]
endpoint = "http://{{ vector.vmagent_vector.service_name }}.{{ telemetry_namespace }}.svc.cluster.local:{{ vector.vmagent_vector.port }}/api/v1/write"
healthcheck.enabled = false

[sinks.victoria_metrics.batch]
max_bytes = 1048576
timeout_secs = 5

[sinks.victoria_metrics.buffer]
type = "memory"
max_events = 10000

[sinks.victoria_metrics.request]
retry_attempts = 5
retry_max_duration_secs = 300
timeout_secs = 60
{% endif %}

{% if telemetry_config.telemetry_bridges.vector_ome.logs_enabled | default(false) | bool %}
# SINK: HTTP JSON Lines to vlagent-vector (Logs)
# Data flow: Vector-OME → vlagent-vector:9427 → vlinsert:9481 → VictoriaLogs
[sinks.victoria_logs]
type = "http"
inputs = ["ome_log_enricher"]
uri = "http://{{ vector.vlagent_vector.service_name }}.{{ telemetry_namespace }}.svc.cluster.local:{{ vector.vlagent_vector.port }}/insert/jsonline"
method = "post"
healthcheck.enabled = false

[sinks.victoria_logs.encoding]
codec = "json"

[sinks.victoria_logs.framing]
method = "newline_delimited"

[sinks.victoria_logs.batch]
max_bytes = 1048576
timeout_secs = 5

[sinks.victoria_logs.buffer]
type = "memory"
max_events = 10000

[sinks.victoria_logs.request]
retry_attempts = 5
retry_max_duration_secs = 300
timeout_secs = 60
{% endif %}

# ============================================================================
# INTERNAL TELEMETRY: Vector Self-Monitoring
# ============================================================================
# Expose Vector internal metrics and health on port {{ vector.ome.metrics_port }}
# Vector serves both /health and /metrics on the same API endpoint
# Scraped by vmagent for Vector pipeline monitoring
[api]
enabled = true
address = "0.0.0.0:{{ vector.ome.metrics_port }}"
playground = false
