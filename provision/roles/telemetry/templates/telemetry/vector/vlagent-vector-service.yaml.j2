# vlagent-vector Service
# Purpose: ClusterIP service for vlagent-vector log write-buffer
# Exposes: Port 9427 (HTTP) for JSON Lines from Vector pods
# Spec Reference: Vector HLD Engineering Spec §4.1.3.2

apiVersion: v1
kind: Service
metadata:
  name: vlagent-vector
  namespace: {{ telemetry_namespace }}
  labels:
    app: vlagent-vector
    component: vector
    role: log-write-buffer
spec:
  type: ClusterIP
  selector:
    app: vlagent-vector
  ports:
    - name: http
      port: 9427
      targetPort: 9427
      protocol: TCP
