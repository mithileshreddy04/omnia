# ===========================================================================
# CoreDNS Corefile for OpenCHAMI v2.2 Upgrade
# ===========================================================================
# CRITICAL: Binds to auto-detected external interface IP, NOT 0.0.0.0
# WHY: Binding to 0.0.0.0:53 conflicts with aardvark-dns (Podman DNS)
# SOLUTION: Use detected_cluster_boot_ip from upgrade playbook
# NO admin_nic_ip DEPENDENCY: Uses runtime interface detection
# ===========================================================================

.:53 {
    # Enable readiness endpoint.
    #ready

    # Bind Prometheus metrics endpoint.
    prometheus 0.0.0.0:9153

    # Bind to specific IP address (auto-detected from default interface).
    # CRITICAL: Must NOT be 0.0.0.0 to avoid conflict with aardvark-dns
    bind {{ detected_cluster_boot_ip | default(cluster_boot_ip | default('127.0.0.1')) }}

    # Specify DNS forwarders.
    forward . {{ dns_forwarders | default(['8.8.8.8', '1.1.1.1']) | join(' ') }}

    # Generate DNS records based on BMC and node data in SMD.
    coresmd {
        # Base URI of OpenCHAMI cluster. The SMD base endpoint is appended to this
        # when requesting node and BMC data from SMD.
        smd_url {{ ochami_base_url | default('https://localhost:8443') }}

        # Path to CA certificate bundle to use when verifying TLS for smd_url.
        ca_cert {{ ca_cert_path | default('/root_ca/root_ca.crt') }}

        # Frequency to update the SMD data cache.
        cache_duration 30s

        # DNS zone configurations based on records generated from SMD data.
        zone {{ cluster_domain | default('openchami.cluster') }} {
            # Besides generating DNS records for nodes based on xname, a custom
            # record format can be specified based on the node ID. For instance:
            #
            # nodes de{03d}
            #
            # will produce:
            #
            # de001.openchami.cluster
            #
            # for node ID 1 and domain openchami.cluster.
            nodes {{ cluster_shortname | default('node') }}{0{{ cluster_nidlength | default('3') }}d}
        }
    }
}
