---

[Unit]
Description=OpenCHAMI CoreDNS Service
Wants=network-online.target
After=network-online.target
Wants=openchami-internal-network.target
After=openchami-internal-network.target
PartOf=openchami.target

[Container]
Image=ghcr.io/openchami/coresmd:{{ openchami_coresmd_tag }}
ContainerName=coresmd-coredns
Exec=--config=/etc/coredns/Corefile --mode=coredns
Network=openchami.internal
PublishPort=127.0.0.1:53:53/udp
PublishPort=127.0.0.1:53:53/tcp
PodmanArgs=--cap-add=NET_ADMIN
Volume=/etc/openchami/configs/Corefile:/etc/coredns/Corefile:ro
HealthCmd=coresmd --health-check --mode=coredns
HealthInterval=30s
HealthTimeout=10s
HealthRetries=3
Restart=on-failure

[Install]
RequiredBy=openchami.target
WantedBy=multi-user.target
