# Omnia Test Configuration for Automation Framework
# Generated by prepare_oim role - configure_automation.yml task
# Component 5 Validate Module Spec - Phase 2 Implementation
# 
# This configuration enables LOCAL EXECUTION MODE by leaving oim_server_ip empty.
# In local mode, automation commands execute directly via subprocess on the OIM host
# where podman is available, eliminating the need for SSH credentials to the OIM itself.

# OIM Server Configuration - LOCAL EXECUTION MODE
# Empty oim_server_ip triggers local execution mode in automation_library/core/host.py
oim_server_ip: ""  # CRITICAL: Empty string enables local execution mode
oim_ssh_user: ""   # Not needed in local mode
oim_ssh_password: ""  # Not needed in local mode

# Dataset and Artifact Paths
dataset_path: "{{ automation_dataset_path }}"
nfs_share_path: "{{ automation_nfs_share_path }}"

# Automation Framework Configuration
automation_base_dir: "{{ automation_base_dir }}"
automation_config_file: "{{ automation_config_file }}"

# Test Execution Settings
default_timeout_minutes: {{ automation_default_timeout }}
max_retries: {{ automation_max_retries }}

# Molecule Configuration
molecule_scenarios_dir: "{{ automation_base_dir }}/molecule"
molecule_report_dir: "{{ automation_nfs_share_path }}"

# Virtual Environment Path
venv_path: "{{ automation_venv_dir }}"

# Logging Configuration
log_level: "{{ automation_log_level | default('INFO') }}"
log_file: "{{ automation_base_dir }}/automation.log"

# Generated Configuration Metadata
generated_by: "prepare_oim/roles/deploy_containers/build_stream/tasks/configure_automation.yml"
generated_at: "{{ ansible_date_time.iso8601 }}"
omnia_version: "{{ ansible_local.omnia.version | default('2.1.0') }}"
execution_mode: "local"  # local execution mode - no SSH to OIM required
